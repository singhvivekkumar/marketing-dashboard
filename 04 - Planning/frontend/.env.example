# ─────────────────────────────────────────────────────────────────────────────
# Marketing Portal — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be accessible in React code.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Development:  http://localhost:5000/api
# Production:   http://YOUR_SERVER_IP/api  (Nginx proxies this)
VITE_API_URL=http://localhost:5000/api

# App name (shown in browser tab)
VITE_APP_NAME=Marketing Portal
