# ─────────────────────────────────────────────────────────────────────────────
# Marketing Portal — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development          # development | production

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketing_portal
DB_USER=mp_user
DB_PASSWORD=your_strong_password_here

# JWT Authentication
JWT_SECRET=replace_this_with_a_random_64_character_string_minimum
JWT_EXPIRES_IN=8h             # token valid for 8 hours of activity

# Local File Storage (on-premises)
UPLOAD_PATH=./uploads         # relative to backend/
MAX_FILE_SIZE_MB=20

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
